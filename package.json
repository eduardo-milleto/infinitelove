{
  "name": "infinitelove",
  "private": true,
  "version": "0.1.0",
  "description": "Site do namoro Eduardo & Isabella — estilo Stardew Valley",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "seed": "pnpm --filter api seed",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:push": "pnpm --filter api db:push"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.45.2"
    },
    "peerDependencyRules": {
      "ignoreMissing": ["zod"],
      "allowedVersions": {
        "zod": "*"
      }
    }
  }
}
